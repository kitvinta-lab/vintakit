rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can READ the store data (products, whatsapp number, about text)
    // so visitors can browse the shop without logging in.
    // Only a signed-in admin (via Firebase Authentication) can WRITE.

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
